# Base URL of the Ari app under test
BASE_URL=http://localhost:8081

# Docker image to use (leave empty to build from source)
ARI_IMAGE=

# Path to the ari/ source directory (for building from source)
ARI_SOURCE_DIR=../ari

# Ports (defaults chosen to avoid conflicts with dev on 8080/8025)
APP_PORT=8081
MAILPIT_PORT=8026
MOCK_GOOGLE_PORT=4020
MOCK_TELEGRAM_PORT=4021
